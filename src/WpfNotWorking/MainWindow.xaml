<Window x:Class="WpfIssue.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfIssue"
        xmlns:wpf="http://schemas.microsoft.com/winfx/2006/xaml/presentation/blazor"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFEF">
    <Grid Background="#ECEFEF">
        <wpf:BlazorWebView x:Name="BlazorWebView" HostPage="wwwroot\index.html">
            <wpf:BlazorWebView.RootComponents>
                <wpf:RootComponent x:Name="RootComponent" Selector="#app" ComponentType="{x:Type local:AppBlazor}" />
            </wpf:BlazorWebView.RootComponents>
        </wpf:BlazorWebView>

        <Grid x:Name="StartupOverlay" Panel.ZIndex="1" Background="#ECEFEF">
            <Ellipse Width="360"
                     Height="360"
                     Margin="-120,-140,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#4D00ECC9" Offset="0" />
                        <GradientStop Color="#1FCDF8EB" Offset="0.45" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="320"
                     Height="320"
                     Margin="0,0,-150,-170"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#29004152" Offset="0" />
                        <GradientStop Color="#12004152" Offset="0.45" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border MaxWidth="460"
                    Margin="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="24"
                    BorderBrush="#14004152"
                    BorderThickness="1"
                    Background="#F7FFFFFF">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32"
                                      ShadowDepth="0"
                                      Opacity="0.15"
                                      Color="#004152" />
                </Border.Effect>

                <Grid>
                    <Border x:Name="CardClipSource" CornerRadius="23" Background="White" />

                    <Grid>
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=CardClipSource}" />
                        </Grid.OpacityMask>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#CDF8EB" Offset="0" />
                                    <GradientStop Color="#00BEA2" Offset="0.52" />
                                    <GradientStop Color="#00A861" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid Grid.Column="1" Margin="28,28,28,30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                HorizontalAlignment="Center"
                                Padding="12,7"
                                CornerRadius="999"
                                Background="#FFF5F8F7">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#00ECC9" Margin="0,0,8,0" />
                                    <TextBlock Text="Tallink"
                                           Foreground="#467480"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1"
                              Width="136"
                              Height="136"
                              Margin="0,20,0,0"
                              HorizontalAlignment="Center">
                                <Border Margin="10"
                                    CornerRadius="30"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <RotateTransform Angle="-6" />
                                    </Border.RenderTransform>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#CDF8EB" Offset="0" />
                                            <GradientStop Color="#ECFEF8" Offset="0.48" />
                                            <GradientStop Color="#F5F8F7" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="22"
                                                      ShadowDepth="0"
                                                      Opacity="0.14"
                                                      Color="#004152" />
                                    </Border.Effect>
                                </Border>

                                <Viewbox Width="78"
                                     Height="78"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Stretch="Uniform">
                                    <Canvas Width="96" Height="96">
                                        <Canvas Width="32" Height="23" Canvas.Left="31.5" Canvas.Top="33">
                                            <Path Fill="#467480"
                                              Stretch="Uniform"
                                              Data="m 14.867,9.0384575 a 2.438,2.438 0 0 0 -2.438,2.4300005 h 1.258 a 1.18,1.18 0 0 1 2.359,0 h 1.259 c 0,-1.339 -1.094,-2.4300005 -2.438,-2.4300005 z" Canvas.Left="13.562" Canvas.Top="6.409" />
                                            <Path Fill="#467480"
                                              Stretch="Uniform"
                                              Data="m 29.546,13.935458 c -0.175,0.816 -0.792,1.742 -2.107,2.423 v -2.675 h 2.147 c -0.009,0.085 -0.023,0.17 -0.04,0.253 m -0.165,-3.555 L 18.01,5.1514575 c -2.302,-1.007 -4.479,-1.15 -6.293,-0.412 -1.786,0.727 -3.152,2.23 -4.056,4.47 -0.315,0.777 -0.607,1.5170005 -0.899,2.2600005 -0.9118,2.359655 -1.80516,4.726393 -2.68,7.1 -0.72,1.935 -1.579,4.24 -2.675,7.154 h 2.42 c 0.956,-2.54 1.725,-4.614 2.378,-6.368 1.484,-3.988 2.381,-6.394 3.556,-9.303 0.669,-1.6510005 1.615,-2.7350005 2.811,-3.2210005 1.236,-0.502 2.944,-0.273 4.684,0.45 1.377,0.573 9.145,3.7560005 11.112,4.5840005 H 22.91 v 1.818 h 2.705 v 3.35 c -0.846,0.201 -1.712,0.301 -2.582,0.297 -2.033,0 -3.446,-0.759 -4.244,-1.359 l -1.353,1.35 c 1.371,1.172 3.44,2.002 5.565,2.002 0.423,0 0.829,-0.017 1.221,-0.048 l 1.945,6.45 h 2.363 l -2.055,-6.822 c 1.313,-0.347 2.201,-0.888 3.022,-1.539 1.278,-1.015 2.096,-2.52 2.096,-3.95 0,-1.129 -0.385,-2.154 -2.212-3.033" Height="28" Width="40" />
                                        </Canvas>
                                    </Canvas>
                                </Viewbox>
                            </Grid>

                            <StackPanel Grid.Row="2" Margin="0,18,0,0">
                                <TextBlock Text="Just a moment"
                                       HorizontalAlignment="Center"
                                       Foreground="#004152"
                                       FontSize="31"
                                       FontWeight="Medium" />
                                <TextBlock Text="Liisu is starting up."
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       Foreground="#467480"
                                       FontSize="16" />
                            </StackPanel>

                            <StackPanel Grid.Row="3"
                                    Margin="0,20,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Margin="0,0,8,0" Fill="#00ECC9" Opacity="0.45" />
                                <Ellipse Width="12" Height="12" Margin="0,0,8,0" Fill="#00ECC9" Opacity="0.6" />
                                <Ellipse Width="12" Height="12" Margin="0,0,8,0" Fill="#00ECC9" Opacity="0.8" />
                                <Ellipse Width="12" Height="12" Fill="#00ECC9" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

